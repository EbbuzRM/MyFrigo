{
  "name": "myfrigo",
  "version": "1.0.3",
  "main": "index.js",
  "scripts": {
    "android": "expo run:android",
    "android:dev": "expo run:android --variant dev",
    "android:prod": "expo run:android --variant release",
    "ios": "expo run:ios",
    "ios:dev": "expo run:ios --configuration Debug",
    "ios:prod": "expo run:ios --configuration Release",
    "start": "expo start",
    "start:clear": "expo start --clear",
    "start:web": "expo start --web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "build": "eas build --platform all",
    "build:android:dev": "eas build --platform android --profile development",
    "build:android:prod": "expo build:android",
    "build:ios:dev": "eas build --platform ios --profile development",
    "build:ios:prod": "expo build:ios",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios",
    "lint": "expo lint",
    "lint:fix": "expo lint --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "clean": "expo install --fix",
    "clean:metro": "npx react-native start --reset-cache",
    "clean:android": "cd android && ./gradlew clean",
    "install:deps": "npm install",
    "update:deps": "npx npm-check-updates -u && npm install",
    "dev": "npm run start",
    "dev:android": "npm run start:clear && npm run android",
    "dev:ios": "npm run start:clear && npm run ios",
    "serve": "npm run start:web",
    "analyze": "npx depcheck",
    "doctor": "expo doctor",
    "eas:update": "eas update",
    "eas:update:preview": "eas update --branch preview",
    "eas:update:production": "eas update --branch production",
    "eas:build:preview": "eas build --platform android --profile preview",
    "eas:build:production": "eas build --platform android --profile production"
  },
